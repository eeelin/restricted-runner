#!/usr/bin/env bash
set -euo pipefail

require_bin() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing required command: $1" >&2
    exit 127
  fi
}

require_bin jq
require_bin ssh

usage() {
  cat <<'EOF'
usage: rr-exec \
  --host <ssh-host> \
  --caller <caller-id> \
  --target <logical-target> \
  --script <relative-script> \
  [--preflight] \
  [--arg <value> ...] \
  [--env KEY=VALUE ...] \
  [--stdin-file <path>] \
  [--port <port>] \
  [--identity <path>] \
  [--ssh-option <option> ...]

The command sends a JSON request over SSH stdin to a host configured with
restricted-runner forced-command mode. `--target` is the logical policy target,
not a filesystem path. Use --preflight to request remote dispatch preflight
without real execution.
EOF
}

HOST=
CALLER=
TARGET=
SCRIPT=
PORT=
IDENTITY=
STDIN_FILE=
PREFLIGHT=0
ARGS_JSON='[]'
ENV_JSON='{}'
SSH_OPTIONS=()

append_json_array() {
  local current=$1
  local value=$2
  jq -cn --argjson current "$current" --arg value "$value" '$current + [$value]'
}

append_json_object() {
  local current=$1
  local key=$2
  local value=$3
  jq -cn --argjson current "$current" --arg key "$key" --arg value "$value" '$current + {($key): $value}'
}

while [ $# -gt 0 ]; do
  case "$1" in
    --host)
      HOST=${2:?missing value for --host}
      shift 2
      ;;
    --caller)
      CALLER=${2:?missing value for --caller}
      shift 2
      ;;
    --target)
      TARGET=${2:?missing value for --target}
      shift 2
      ;;
    --script)
      SCRIPT=${2:?missing value for --script}
      shift 2
      ;;
    --preflight)
      PREFLIGHT=1
      shift
      ;;
    --arg)
      ARGS_JSON=$(append_json_array "$ARGS_JSON" "${2:?missing value for --arg}")
      shift 2
      ;;
    --env)
      pair=${2:?missing value for --env}
      key=${pair%%=*}
      value=${pair#*=}
      if [ -z "$key" ] || [ "$key" = "$pair" ]; then
        echo "invalid --env value: $pair" >&2
        exit 2
      fi
      ENV_JSON=$(append_json_object "$ENV_JSON" "$key" "$value")
      shift 2
      ;;
    --stdin-file)
      STDIN_FILE=${2:?missing value for --stdin-file}
      shift 2
      ;;
    --port)
      PORT=${2:?missing value for --port}
      shift 2
      ;;
    --identity)
      IDENTITY=${2:?missing value for --identity}
      shift 2
      ;;
    --ssh-option)
      SSH_OPTIONS+=("${2:?missing value for --ssh-option}")
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [ -z "$HOST" ] || [ -z "$CALLER" ] || [ -z "$TARGET" ] || [ -z "$SCRIPT" ]; then
  usage >&2
  exit 2
fi

STDIN_CONTENT=''
if [ -n "$STDIN_FILE" ]; then
  STDIN_CONTENT=$(cat "$STDIN_FILE")
fi

REQUEST=$(jq -cn \
  --arg version v1 \
  --arg request_id "rr-$(date +%s)" \
  --arg script "$SCRIPT" \
  --arg stdin "$STDIN_CONTENT" \
  --argjson argv "$ARGS_JSON" \
  --argjson env "$ENV_JSON" \
  '{version:$version, request_id:$request_id, script:$script, argv:$argv, env:$env} + (if $stdin != "" then {stdin:$stdin} else {} end)')

export RR_CALLER="$CALLER"
export RR_TARGET="$TARGET"
if [ "$PREFLIGHT" = "1" ]; then
  export RR_PREFLIGHT=1
else
  unset RR_PREFLIGHT || true
fi

SSH_CMD=(ssh -T -o SendEnv=RR_CALLER -o SendEnv=RR_TARGET -o SendEnv=RR_PREFLIGHT)
if [ -n "$PORT" ]; then
  SSH_CMD+=( -p "$PORT" )
fi
if [ -n "$IDENTITY" ]; then
  SSH_CMD+=( -i "$IDENTITY" )
fi
for opt in "${SSH_OPTIONS[@]}"; do
  SSH_CMD+=( -o "$opt" )
done
SSH_CMD+=("$HOST")

set +e
RESPONSE=$(printf '%s' "$REQUEST" | "${SSH_CMD[@]}" 2>&1)
SSH_STATUS=$?
set -e

printf '%s\n' "$RESPONSE"

if printf '%s' "$RESPONSE" | jq -e . >/dev/null 2>&1; then
  OK=$(printf '%s' "$RESPONSE" | jq -r '.ok // false')
  if [ "$OK" != "true" ]; then
    exit 1
  fi
  if [ "$SSH_STATUS" -ne 0 ]; then
    exit "$SSH_STATUS"
  fi
  exit 0
fi

if [ "$SSH_STATUS" -ne 0 ]; then
  exit "$SSH_STATUS"
fi

exit 1
